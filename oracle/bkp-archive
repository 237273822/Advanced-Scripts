#!/bin/bash
#
# ---------------------------------------------------------------------------
# Script: backup_archivelog_rman.sh
# Objetivo:
#   Executar rotina de backup de archivelogs e controlfile via RMAN,
#   remover arquivos antigos de backup/log, consultar o status final
#   da execução e enviar notificação por e-mail com o log em anexo.
#
# Observações:
#   - Este exemplo utiliza dados fictícios.
#   - Em ambiente real, evite armazenar senha SMTP e senha de banco em texto claro.
#   - Prefira Oracle Wallet / OS Authentication / variáveis protegidas.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# 1) Variáveis de ambiente Oracle
# ---------------------------------------------------------------------------
export ORACLE_SID=DBPRD
export ORACLE_BASE=/u01/app/oracle
export ORACLE_HOME=/u01/app/oracle/product/19.0.0.0/dbhome_1
export PATH=$PATH:$HOME/.local/bin:$HOME/bin:$ORACLE_BASE:$ORACLE_HOME:$ORACLE_HOME/bin

# Data/hora utilizada para identificar log e command_id da execução
export DATE=$(date +%d-%m-%y_%H%M%S)

# ---------------------------------------------------------------------------
# 2) Limpeza de arquivos antigos
#    - Remove backups de archivelog com mais de 7 dias
#    - Remove logs da rotina com mais de 7 dias
# ---------------------------------------------------------------------------
find /backup/rman/archivelog/ -type f -mtime +7 -exec rm -f {} \;
find /backup/logs_rman/ -iname "DBPRD_arc_*" -type f -mtime +7 -exec rm -f {} \;

# Identificador único da execução no RMAN
RUN_ID="ARC_${DATE}"

# ---------------------------------------------------------------------------
# 3) Execução do RMAN
#    Etapas:
#      - Define COMMAND ID para rastreabilidade
#      - Aloca canal em disco
#      - Faz crosscheck dos archivelogs
#      - Remove archivelogs já copiados pelo menos 1 vez para disco
#      - Força log switch
#      - Realiza backup dos archivelogs ainda não copiados
#      - Realiza backup do controlfile atual
# ---------------------------------------------------------------------------
rman target / log=/backup/logs_rman/DBPRD_arc_${DATE}.log << EOF

set echo on;

run {
    set command id to '${RUN_ID}';
    allocate channel ch01 device type disk;
    crosscheck archivelog all;
    delete noprompt archivelog all backed up 1 times to disk;
    sql 'alter system archive log current';

    backup format '/backup/rman/archivelog/archive-%T-%I-%d-%s.bkp'
        archivelog all not backed up
        tag 'BKP_ARCHIVELOG';
        
    backup format '/backup/rman/controlfile/control-%T-%I-%d-%s.bkp'
        current controlfile;

    release channel ch01;
}
EOF

# ---------------------------------------------------------------------------
# 4) Consulta o status final da execução RMAN
#    Busca o status mais recente da execução com base no COMMAND_ID
#    na view V$RMAN_BACKUP_JOB_DETAILS.
# ---------------------------------------------------------------------------
status_last_backup=$(sqlplus -s system/SenhaFicticia123<<EOF
set newpage 0
set echo off
set feedback off
set heading off
set pages 0
set verify off
set trimspool on
SELECT status
FROM V\$RMAN_BACKUP_JOB_DETAILS
WHERE command_id = '${RUN_ID}'
  AND status NOT LIKE 'RUNNING%'
ORDER BY end_time DESC
FETCH FIRST 1 ROWS ONLY;
exit
EOF
)

# Remove espaços em branco extras da saída
status_last_backup=$(echo "$status_last_backup" | xargs)

# ---------------------------------------------------------------------------
# 5) Configuração comum de envio de e-mail
# ---------------------------------------------------------------------------
EMAIL_SUBJECT="Rotina Backup Archives"
FROM_EMAIL_ADDRESS="backup.monitor@empresa.com"
FRIENDLY_NAME="RMAN Backup"
SMTP_SERVER="smtp.office365.com"
SMTP_PORT="587"
SMTP_USER="backup.monitor@empresa.com"
SMTP_PASS="SenhaSMTPFicticia@123"
TO_EMAIL_ADDRESS="dba1@empresa.com dba2@empresa.com"
FILEPATH="/backup/logs_rman/DBPRD_arc_${DATE}.log"

# Diretório NSS usado pelo mailx para TLS/SSL
NSS_DIR="/etc/pki/nssdb/"

# ---------------------------------------------------------------------------
# 6) Envio de e-mail conforme resultado da rotina
#    - Se status = FAILED, envia alerta de falha
#    - Caso contrário, envia mensagem de sucesso
# ---------------------------------------------------------------------------
if [[ "$status_last_backup" = "FAILED" ]]; then
    MESSAGE_BODY="========== BACKUP TERMINADO COM FALHAS =========="
    echo "$MESSAGE_BODY" | mailx -v -s "$EMAIL_SUBJECT" \
        -S smtp-use-starttls \
        -S ssl-verify=ignore \
        -S smtp=smtp://$SMTP_SERVER:$SMTP_PORT \
        -S from="$FROM_EMAIL_ADDRESS($FRIENDLY_NAME)" \
        -S smtp-auth-user=$SMTP_USER \
        -S smtp-auth-password=$SMTP_PASS \
        -S nss-config-dir=$NSS_DIR \
        -a "$FILEPATH" \
        $TO_EMAIL_ADDRESS
else
    
    MESSAGE_BODY="========== BACKUP TERMINADO COM SUCESSO =========="
    echo "$MESSAGE_BODY" | mailx -v -s "$EMAIL_SUBJECT" \
        -S smtp-use-starttls \
        -S ssl-verify=ignore \
        -S smtp=smtp://$SMTP_SERVER:$SMTP_PORT \
        -S from="$FROM_EMAIL_ADDRESS($FRIENDLY_NAME)" \
        -S smtp-auth-user=$SMTP_USER \
        -S smtp-auth-password=$SMTP_PASS \
        -S nss-config-dir=$NSS_DIR \
        -a "$FILEPATH" \
        $TO_EMAIL_ADDRESS
fi
